<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
      <link rel="stylesheet" href="/stylesheets/style.css">
      <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="h-full">
    <div class="w-full h-full bg-zinc-900 p-10 text-white gap-4">
        <div class="nav mb-10">
            <a href="/read" class="text-blue-700">Read Users</a>
        </div>
        <h1 class="text-3xl font-bold mb-6">Update User</h1>
        <form action="/update/<%= user._id %>" method="post">
            <input class= "px-5 py-3 bg-zinc-900 rounded-lg border-2 border-zinc-500 outline-none" type="text" name="name" placeholder="name"  value="<%= user.name %>" >
            <input class= "px-5 py-3 bg-zinc-900 rounded-lg border-2 border-zinc-500 outline-none" type="text" name="email" placeholder="email" value="<%= user.email %>" >
            <input class= "px-5 py-3 bg-zinc-900 rounded-lg border-2 border-zinc-500 outline-none" type="text" name="image" placeholder="image url" value="<%= user.image %>">
            <input class="text-black px-5 py-2 bg-yellow-500 rounded-lg ml-3 hover:bg-yellow-200" type="submit" value="Update user">
        </form>
    </div>
</body>
</html>